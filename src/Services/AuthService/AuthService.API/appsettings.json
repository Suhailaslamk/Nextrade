{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "ConnectionStrings": {
    "AuthDb": "Server=.;Database=Nextrade_auth_db;Trusted_Connection=True;TrustServerCertificate=True;",
    "Redis": "localhost:6379,abortConnect=false,connectTimeout=5000,syncTimeout=5000"
  },
  "Jwt": {
    "Issuer": "nextrade-auth",
    "Audience": "nextrade-api",
    "AccessTokenExpiryMinutes": 5,
    "PrivateKeyPem": "",
    "PublicKeyPem": ""
  },
  "RefreshToken": {
    "ExpiryDays": 7
  },
  "Serilog": {
    "SeqUrl": "http://localhost:5341",
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Grpc": "Warning"
      }
    }
  },
  "Otel": {
    "Endpoint": "http://localhost:4317"
  },
  "AllowedHosts": "*"
}